# ── Server ───────────────────────────────────────────────
PORT=4787
PUBLIC_BASE_URL=http://localhost:4787
DATA_DIR=

# ── Sender identity (used in From + compliance footer) ────
SENDER_NAME=Your Name
SENDER_EMAIL=you@example.com
# Physical mailing address is legally required (CAN-SPAM) in marketing email footers.
SENDER_ADDRESS=123 Example St, City, ST 00000

# ── SMTP (outbound mail) ─────────────────────────────────
# Examples: smtp.gmail.com:587, smtp-relay.brevo.com:587, smtp.sendgrid.net:587
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ── Authentication ───────────────────────────────────────
# Login is ON by default. On first run (with auth on) open the app and you'll be
# prompted to create the first admin account; admins add teammates in Settings.
# Set AUTH_DISABLED=1 ONLY for trusted local use (the desktop launcher does this).
# NEVER set AUTH_DISABLED on a hosted/public deployment.
AUTH_DISABLED=

# Safety: when true, NOTHING is actually sent — sends are logged only. Start here.
DRY_RUN=true
# Legacy per-minute throttle (kept for reference; pacing is driven by spacing below).
RATE_PER_MIN=20

# Anti-spam pacing: the worker sends at most one email per this many seconds,
# plus a random jitter on top, so a blast looks human-paced. (Dry-run is ~1s.)
SEND_SPACING_SECONDS=45
SEND_JITTER_SECONDS=15
# Business-hours window (local, 24h) that scheduled follow-ups are pulled into.
SEND_WINDOW_START_HOUR=9
SEND_WINDOW_END_HOUR=17

# ── AI copy generation ───────────────────────────────────
# Provider: "ollama" (local, free) or "claude" (Anthropic API)
AI_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
# Only needed if AI_PROVIDER=claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# ── Make.com integration (optional) ──────────────────────
# Outbound: we POST campaign/contact events to this Make.com webhook URL.
MAKE_WEBHOOK_URL=
# Inbound: shared secret required to trigger campaigns via our /webhooks/make endpoint.
MAKE_INBOUND_SECRET=
